{
  "base_config": "configs/baseline_catboost_time_no_time_context_offer.json",
  "out_dir": "reports/validation",
  "study_name": "optuna_catboost_context_offer_fold3_hpo_ext1",
  "storage": "sqlite:///reports/validation/optuna_catboost_context_offer_fold3_hpo_ext1.db",
  "load_if_exists": false,
  "seed": 137,
  "objective_fold": 3,
  "n_trials": 150,
  "n_startup_trials": 40,
  "timeout_seconds": null,
  "show_progress_bar": true,
  "early_stopping_rounds": 200,
  "sampler": {
    "type": "TPESampler",
    "multivariate": true,
    "group": true
  },
  "fixed_model_params": {
    "loss_function": "Logloss",
    "eval_metric": "AUC"
  },
  "search_space": {
    "iterations": {
      "type": "int",
      "low": 800,
      "high": 2500
    },
    "learning_rate": {
      "type": "float",
      "low": 0.008,
      "high": 0.065,
      "log": true
    },
    "depth": {
      "type": "int",
      "low": 4,
      "high": 8
    },
    "l2_leaf_reg": {
      "type": "float",
      "low": 2.0,
      "high": 80.0,
      "log": true
    },
    "random_strength": {
      "type": "float",
      "low": 0.05,
      "high": 15.0,
      "log": true
    },
    "bagging_temperature": {
      "type": "float",
      "low": 0.0,
      "high": 5.0
    },
    "border_count": {
      "type": "categorical",
      "choices": [
        32,
        64,
        128,
        254
      ]
    },
    "auto_class_weights": {
      "type": "categorical",
      "choices": [
        "Balanced",
        "SqrtBalanced",
        null
      ]
    },
    "grow_policy": {
      "type": "categorical",
      "choices": [
        "SymmetricTree",
        "Depthwise"
      ]
    },
    "min_data_in_leaf": {
      "type": "int",
      "low": 20,
      "high": 200
    }
  },
  "conditional_search_space": {
    "grow_policy==Depthwise": {
      "min_data_in_leaf": {
        "type": "int",
        "low": 20,
        "high": 200
      }
    }
  },
  "selection_note": "Fold3 HPO screen only. Top trials must be revalidated on all rolling folds before blending.",
  "reset_existing_artifacts": true
}
