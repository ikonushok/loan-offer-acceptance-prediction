{
  "train": "data/raw/train_apps.csv",
  "test": "data/raw/test_apps.csv",
  "out_dir": "experiments/runs",
  "seed": 42,
  "cutoffs": [
    "2025-01-01",
    "2025-03-01",
    "2025-04-01"
  ],
  "time_features": {
    "enabled": false
  },
  "feature_engineering": {
    "enabled": true,
    "add_pairwise_features": false,
    "add_missing_flags": false,
    "add_context_offer_features": true
  },
  "sample_weight": {
    "enabled": false
  },
  "run_prefix": "xgb_hpo_depth5_child120_reg40_v1",
  "model": {
    "n_estimators": 1700,
    "learning_rate": 0.018,
    "max_depth": 5,
    "min_child_weight": 120,
    "subsample": 0.85,
    "colsample_bytree": 0.85,
    "reg_alpha": 1.0,
    "reg_lambda": 40.0,
    "gamma": 0.0,
    "max_cat_to_onehot": 8,
    "early_stopping_rounds": 100
  },
  "diversity_experiment": {
    "purpose": "XGBoost diversity candidate using same time folds and context-offer features as CatBoost champion.",
    "selection_gate": "Keep only if constrained blend improves Fold3 and OOF."
  },
  "xgb_hpo_note": {
    "base_config": "configs/diversity_experiments/xgb_context_offer_unweighted_v1.json",
    "objective": "Improve Fold3 and constrained blend while keeping OOF stable; no public score used."
  }
}
