{
  "train": "data/raw/train_apps.csv",
  "test": "data/raw/test_apps.csv",
  "out_dir": "experiments/runs",
  "seed": 42,
  "cutoffs": [
    "2025-01-01",
    "2025-03-01",
    "2025-04-01"
  ],
  "early_stopping_rounds": 150,
  "time_features": {
    "enabled": false
  },
  "feature_engineering": {
    "enabled": true,
    "add_pairwise_features": false,
    "add_missing_flags": false,
    "add_context_offer_features": true
  },
  "sample_weight": {
    "enabled": false
  },
  "run_prefix": "lgbm_context_offer_balanced_v1",
  "model": {
    "n_estimators": 2500,
    "learning_rate": 0.02,
    "num_leaves": 31,
    "max_depth": -1,
    "min_child_samples": 120,
    "subsample": 0.85,
    "subsample_freq": 1,
    "colsample_bytree": 0.85,
    "reg_alpha": 0.5,
    "reg_lambda": 15.0,
    "min_split_gain": 0.0,
    "class_weight": "balanced",
    "boosting_type": "gbdt"
  },
  "diversity_experiment": {
    "purpose": "LightGBM diversity candidate using same time folds and context-offer features as CatBoost champion.",
    "selection_gate": "Keep only if it improves constrained blend or shows useful low-correlation Fold3 behavior."
  }
}
