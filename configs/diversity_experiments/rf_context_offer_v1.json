{
  "train": "data/raw/train_apps.csv",
  "test": "data/raw/test_apps.csv",
  "out_dir": "experiments/runs",
  "seed": 42,
  "cutoffs": [
    "2025-01-01",
    "2025-03-01",
    "2025-04-01"
  ],
  "time_features": {
    "enabled": false
  },
  "feature_engineering": {
    "enabled": true,
    "add_pairwise_features": false,
    "add_missing_flags": false,
    "add_context_offer_features": true
  },
  "sample_weight": {
    "enabled": false
  },
  "run_prefix": "rf_context_offer_v1",
  "model": {
    "model_type": "RandomForestClassifier",
    "n_estimators": 600,
    "max_depth": 14,
    "min_samples_leaf": 30,
    "min_samples_split": 60,
    "max_features": "sqrt",
    "class_weight": "balanced",
    "n_jobs": -1,
    "bootstrap": true,
    "max_samples": 0.8
  },
  "diversity_experiment": {
    "purpose": "RandomForest diversity candidate — lower variance than ExtraTrees, moderate correlation with GBM.",
    "selection_gate": "Keep only if it improves constrained Fold3/late-holdout blend."
  }
}
